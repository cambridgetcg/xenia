{
  "name": "@sinovai/xenia",
  "version": "0.1.0-beta.1",
  "private": true,
  "description": "Runtime-neutral tools for practising and observing XENIA guest-right.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CONFORMANCE.md",
    "CONTRIBUTING.md",
    "PACKAGE.md",
    "LICENSE",
    "LICENSE-CODE",
    "LICENSE-DOCS",
    "LICENSES.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "npm run build && npm run test:types && node --test tests/*.test.mjs",
    "test:types": "tsc -p tsconfig.type-tests.json",
    "pack:check": "npm pack --dry-run --json",
    "prepare": "npm run build",
    "prepack": "npm test"
  },
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "license": "SEE LICENSE IN LICENSES.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cambridgetcg/xenia.git"
  },
  "homepage": "https://github.com/cambridgetcg/xenia#readme",
  "bugs": {
    "url": "https://github.com/cambridgetcg/xenia/issues"
  },
  "keywords": [
    "agents",
    "agent-experience",
    "agent-interaction",
    "xenia"
  ],
  "devDependencies": {
    "typescript": "~7.0.2"
  }
}
